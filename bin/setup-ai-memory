#!/usr/bin/env bash
# Bootstrap ~/.ai/ on a new machine:
#   1. Initialize the shared AI repo at ~/.ai/ if missing (memory + project notes)
#   2. Generate and load the auto-sync agent (launchd on macOS, systemd on Linux)
#
# Idempotent — safe to run repeatedly. Coexists with the dotfiles linker that
# manages ~/.ai/agents/ and ~/.ai/hooks/ — those are gitignored in this repo.

set -euo pipefail

REPO_URL="${AI_MEMORY_REPO:-git@github.com:aykhaiweng/ai-memory.git}"
REPO_DIR="$HOME/.ai"
LABEL="com.aykhaiweng.ai-memory-sync"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
SYNC_BIN="$HOME/.dotfiles/bin/ai-memory-sync"

# 1. Initialize repo if missing.
# Can't use plain `git clone` because ~/.ai/ may already have agents/ + hooks/
# symlinks from the dotfiles linker. Instead: init + fetch + reset.
if [[ ! -d "$REPO_DIR/.git" ]]; then
  mkdir -p "$REPO_DIR"
  cd "$REPO_DIR"
  git init -b main >/dev/null
  git remote add origin "$REPO_URL"
  git fetch --quiet origin main
  git reset --hard origin/main
  git branch --set-upstream-to=origin/main main >/dev/null
  echo "Bootstrapped $REPO_DIR from $REPO_URL"
else
  echo "Repo already initialized at $REPO_DIR"
fi

# 2. OS-specific auto-sync agent.
OS="$(uname)"

if [[ "$OS" == "Darwin" ]]; then
  if ! command -v fswatch >/dev/null 2>&1; then
    echo "setup-ai-memory: fswatch not installed — run 'brew install fswatch' or re-run dotfiles init" >&2
    exit 1
  fi

  FSWATCH_BIN="$(command -v fswatch)"

  mkdir -p "$(dirname "$PLIST")"
  cat > "$PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${LABEL}</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-c</string>
    <string>${FSWATCH_BIN} -o --latency 30 -e '\.git' "\$HOME/.ai/memory" "\$HOME/.ai/projects" | while read -r _; do "${SYNC_BIN}"; done</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>StandardOutPath</key>
  <string>/tmp/ai-memory-sync.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/ai-memory-sync.err</string>
</dict>
</plist>
PLIST

  launchctl unload "$PLIST" 2>/dev/null || true
  launchctl load -w "$PLIST"
  echo "Loaded launchd agent ${LABEL}"
  echo "Logs: /tmp/ai-memory-sync.{log,err}"

elif [[ "$OS" == "Linux" ]]; then
  if ! command -v systemctl >/dev/null 2>&1; then
    echo "setup-ai-memory: systemctl not found — only systemd-based distros supported on Linux" >&2
    exit 1
  fi

  UNIT_DIR="$HOME/.config/systemd/user"
  mkdir -p "$UNIT_DIR"

  cat > "$UNIT_DIR/ai-memory-sync.service" <<UNIT
[Unit]
Description=Sync ~/.ai/ to its remote (one-shot, debounced)

[Service]
Type=oneshot
# Coalesce a burst of writes (editor save = multiple inotify events) into one sync.
ExecStartPre=/bin/sleep 5
ExecStart=${SYNC_BIN}
UNIT

  # systemd PathModified is NOT recursive: it only fires for direct children of
  # the watched dir. Memory files live flat in ~/.ai/memory/*.md, so the path
  # unit catches those instantly. Project notes live two levels down
  # (~/.ai/projects/<enc>/notes/*.md) and would never trigger it — so a timer
  # below acts as the recursive catch-all (and a safety net for missed events).
  cat > "$UNIT_DIR/ai-memory-sync.path" <<UNIT
[Unit]
Description=Watch ~/.ai/memory and ~/.ai/projects for changes

[Path]
PathModified=%h/.ai/memory
PathModified=%h/.ai/projects

[Install]
WantedBy=default.target
UNIT

  cat > "$UNIT_DIR/ai-memory-sync.timer" <<UNIT
[Unit]
Description=Periodic recursive catch-all for ~/.ai/ sync (nested project notes)

[Timer]
OnBootSec=2min
OnUnitActiveSec=3min
# Don't pile up runs if the machine was asleep.
Persistent=false

[Install]
WantedBy=timers.target
UNIT

  systemctl --user daemon-reload
  systemctl --user enable --now ai-memory-sync.path ai-memory-sync.timer
  echo "Enabled systemd units ai-memory-sync.path (instant memory) + .timer (recursive catch-all)"

  # User-level units stop when the user logs out unless linger is enabled.
  if ! loginctl show-user "$USER" 2>/dev/null | grep -q "Linger=yes"; then
    echo
    echo "NOTE: To keep auto-sync running when you're logged out, enable linger:"
    echo "  sudo loginctl enable-linger \$USER"
  fi

  echo "Logs: journalctl --user -u ai-memory-sync.service -f"

else
  echo "setup-ai-memory: unsupported OS '$OS' — auto-sync agent not installed" >&2
  echo "Repo is initialized and bin/ai-memory-sync works manually."
  exit 0
fi
