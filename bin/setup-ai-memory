#!/usr/bin/env bash
# Bootstrap ~/.ai/memory on a new machine:
#   1. Clone the memory repo if missing
#   2. Generate and load the launchd auto-sync agent (macOS only)
#
# Idempotent — safe to run repeatedly.

set -euo pipefail

REPO_URL="${AI_MEMORY_REPO:-git@github.com:aykhaiweng/ai-memory.git}"
REPO_DIR="$HOME/.ai/memory"
LABEL="com.aykhaiweng.ai-memory-sync"
PLIST="$HOME/Library/LaunchAgents/${LABEL}.plist"
SYNC_BIN="$HOME/.dotfiles/bin/ai-memory-sync"

# 1. Clone if missing.
if [[ ! -d "$REPO_DIR/.git" ]]; then
  mkdir -p "$(dirname "$REPO_DIR")"
  if [[ -d "$REPO_DIR" ]] && [[ -n "$(ls -A "$REPO_DIR" 2>/dev/null)" ]]; then
    echo "setup-ai-memory: $REPO_DIR exists and is non-empty but not a git repo — refusing to clobber" >&2
    exit 1
  fi
  rmdir "$REPO_DIR" 2>/dev/null || true
  git clone "$REPO_URL" "$REPO_DIR"
  echo "Cloned $REPO_URL → $REPO_DIR"
else
  echo "Memory repo already present at $REPO_DIR"
fi

# 2. OS-specific auto-sync agent.
OS="$(uname)"

if [[ "$OS" == "Darwin" ]]; then
  if ! command -v fswatch >/dev/null 2>&1; then
    echo "setup-ai-memory: fswatch not installed — run 'brew install fswatch' or re-run dotfiles init" >&2
    exit 1
  fi

  FSWATCH_BIN="$(command -v fswatch)"

  mkdir -p "$(dirname "$PLIST")"
  cat > "$PLIST" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${LABEL}</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>-c</string>
    <string>${FSWATCH_BIN} -o --latency 30 -e '\.git' "\$HOME/.ai/memory" | while read -r _; do "${SYNC_BIN}"; done</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>

  <key>StandardOutPath</key>
  <string>/tmp/ai-memory-sync.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/ai-memory-sync.err</string>
</dict>
</plist>
PLIST

  launchctl unload "$PLIST" 2>/dev/null || true
  launchctl load -w "$PLIST"
  echo "Loaded launchd agent ${LABEL}"
  echo "Logs: /tmp/ai-memory-sync.{log,err}"

elif [[ "$OS" == "Linux" ]]; then
  if ! command -v systemctl >/dev/null 2>&1; then
    echo "setup-ai-memory: systemctl not found — only systemd-based distros supported on Linux" >&2
    exit 1
  fi

  UNIT_DIR="$HOME/.config/systemd/user"
  mkdir -p "$UNIT_DIR"

  cat > "$UNIT_DIR/ai-memory-sync.service" <<UNIT
[Unit]
Description=Sync ~/.ai/memory to its remote (one-shot, debounced)

[Service]
Type=oneshot
# Coalesce a burst of writes (editor save = multiple inotify events) into one sync.
ExecStartPre=/bin/sleep 5
ExecStart=${SYNC_BIN}
UNIT

  cat > "$UNIT_DIR/ai-memory-sync.path" <<UNIT
[Unit]
Description=Watch ~/.ai/memory for changes

[Path]
PathModified=%h/.ai/memory
# Recursive watch by default for PathModified on directories.

[Install]
WantedBy=default.target
UNIT

  systemctl --user daemon-reload
  systemctl --user enable --now ai-memory-sync.path
  echo "Enabled systemd path unit ai-memory-sync.path"

  # User-level units stop when the user logs out unless linger is enabled.
  if ! loginctl show-user "$USER" 2>/dev/null | grep -q "Linger=yes"; then
    echo
    echo "NOTE: To keep auto-sync running when you're logged out, enable linger:"
    echo "  sudo loginctl enable-linger \$USER"
  fi

  echo "Logs: journalctl --user -u ai-memory-sync.service -f"

else
  echo "setup-ai-memory: unsupported OS '$OS' — auto-sync agent not installed" >&2
  echo "Memory repo is cloned and bin/ai-memory-sync works manually."
  exit 0
fi
