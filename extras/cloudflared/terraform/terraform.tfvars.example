account_id     = "REPLACE_ME"
app_name       = "my-tunnel"
domain_uri     = "*.example.com"
allowed_emails = ["you@example.com"]

# Paths that skip Access entirely (e.g. third-party webhook endpoints).
# Patterns are appended to domain_uri. Omit or set to [] to disable.
bypass_paths = ["/webhooks/*"]
