{
  "permissions": {
    "allow": [
      "Bash(claude mcp *)",
      "Bash(timeout 15 docker run -i --rm hashicorp/terraform-mcp-server)",
      "Bash(echo \"---exit: $?---\")",
      "Bash(jq '\\(.projects[\"/mnt/code/ffg\"].mcpServers.terraform.args\\) = [\"run\",\"-i\",\"--rm\",\"hashicorp/terraform-mcp-server\"] | \\(.projects[\"/mnt/code/ffg\"].mcpServers.github.headers.Authorization\\) = \"Bearer ${GITHUB_TOKEN}\"' ~/.claude.json)",
      "Bash(mv ~/.claude.json.tmp ~/.claude.json)",
      "Bash(python3 -m json.tool)",
      "Bash(pnpm install *)",
      "Bash(npm --version)",
      "Bash(npx --version)",
      "Bash(corepack enable *)",
      "Bash(corepack prepare *)",
      "Bash(pnpm --version)",
      "Bash(npm install *)",
      "Bash(pnpm why *)",
      "Bash(pnpm list *)",
      "Bash(git -C /mnt/code/ffg status)",
      "Bash(git -C /mnt/code/ffg diff --stat)",
      "Bash(git *)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "Bash(npx degit *)",
      "Bash(npx tsc *)",
      "Bash(echo \"Exit: $?\")",
      "WebFetch(domain:developers.xendit.co)",
      "WebFetch(domain:docs.xendit.co)",
      "Bash(docker compose *)",
      "Bash(grep -v \"^$\")"
    ],
    "defaultMode": "default"
  },
  "enabledPlugins": {
    "medusa-dev@medusa": true,
    "ralph-loop@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "medusa": {
      "source": {
        "source": "github",
        "repo": "medusajs/medusa-agent-skills"
      }
    }
  },
  "effortLevel": "high",
  "advisorModel": "opus",
  "skipDangerousModePermissionPrompt": true,
  "theme": "dark",
  "verbose": true,
  "preferredNotifChannel": "terminal_bell",
  "remoteControlAtStartup": true,
  "inputNeededNotifEnabled": true,
  "agentPushNotifEnabled": true
}
